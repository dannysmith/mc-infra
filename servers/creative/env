# Minecraft settings for creative
# Edit these, then restart: mc-stop creative && mc-start creative
# Reference: https://docker-minecraft-server.readthedocs.io/en/latest/configuration/server-properties/
#
# NOTE: Settings managed by manifest.yml (mode, memory, type, version, seed,
# motd, mods) cannot be overridden here. Edit manifest.yml and run mc-generate.

DIFFICULTY=normal
ENABLE_COMMAND_BLOCK=true
# MAX_PLAYERS=20
# VIEW_DISTANCE=10
# SIMULATION_DISTANCE=10
# SPAWN_PROTECTION=0
LEVEL_TYPE=minecraft:flat
GENERATE_STRUCTURES=false
GENERATOR_SETTINGS={"layers":[{"block":"minecraft:bedrock","height":1},{"block":"minecraft:sandstone","height":99}],"biome":"minecraft:desert"}
# FORCE_GAMEMODE=true
# ALLOW_FLIGHT=true
# PVP=true
