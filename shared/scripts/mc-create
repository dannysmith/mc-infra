#!/usr/bin/env python3
"""Create a new Minecraft server.

Adds to manifest.yml, runs mc-generate, creates server directory and env file.
Does NOT start the server — review servers/<name>/env first, then mc-start <name>.
"""

import argparse
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import mclib


def find_project_root():
    d = os.path.dirname(os.path.abspath(__file__))
    while d != '/':
        if os.path.exists(os.path.join(d, 'manifest.yml')):
            return d
        d = os.path.dirname(d)
    print("Error: cannot find manifest.yml", file=sys.stderr)
    sys.exit(1)


def parse_args():
    p = argparse.ArgumentParser(description='Create a new Minecraft server')
    p.add_argument('--name', required=True, help='Server name (lowercase, hyphens ok)')
    p.add_argument('--type', default='FABRIC', choices=['FABRIC', 'VANILLA', 'PAPER'])
    p.add_argument('--version', default='LATEST', help='Minecraft version')
    p.add_argument('--mod-group', action='append', default=None,
                   help='Mod group (repeatable)')
    p.add_argument('--modrinth-mods', default='',
                   help='Modrinth slugs, comma-separated')
    p.add_argument('--jar-mods', default='',
                   help='Filenames from shared/mods/, comma-separated')
    p.add_argument('--memory', default=None, help='Heap size (e.g. 2G, 4G)')
    p.add_argument('--tier', default='ephemeral',
                   choices=['ephemeral', 'semi-permanent', 'permanent'])
    p.add_argument('--mode', default='creative',
                   choices=['creative', 'survival', 'adventure', 'spectator'])
    p.add_argument('--seed', default=None, help='World seed')
    p.add_argument('--motd', default=None, help='Server MOTD')
    p.add_argument('--no-bluemap', action='store_true', help='Disable BlueMap')
    p.add_argument('--svc', action='store_true', help='Enable Simple Voice Chat port')
    p.add_argument('--pregen', nargs='?', const=1500, type=int, default=None,
                   metavar='RADIUS',
                   help='Pre-generate chunks (radius in blocks, default 1500)')
    p.add_argument('--world', default=None,
                   help='World archive (local path or URL) — imported via itzg WORLD env var')
    p.add_argument('--world-from', default=None,
                   help='Copy world data from another server')
    return p.parse_args()


def main():
    args = parse_args()
    root = find_project_root()
    manifest_path = os.path.join(root, 'manifest.yml')
    template_path = os.path.join(root, 'shared', 'templates', 'server-env.template')

    manifest = mclib.load_manifest(manifest_path)

    # Validate world import args
    if args.world and args.world_from:
        print("Error: cannot use both --world and --world-from", file=sys.stderr)
        sys.exit(1)

    if args.world_from and args.world_from not in manifest.get('servers', {}):
        print(f"Error: source server '{args.world_from}' not found", file=sys.stderr)
        sys.exit(1)

    # Build config from args
    config = {
        'type': args.type,
        'version': args.version,
        'mode': args.mode,
        'tier': args.tier,
        'mod_groups': args.mod_group if args.mod_group else ['fabric-base'],
        'modrinth_mods': [m.strip() for m in args.modrinth_mods.split(',') if m.strip()],
        'jar_mods': [m.strip() for m in args.jar_mods.split(',') if m.strip()],
        'svc': args.svc,
        'seed': args.seed,
    }
    if args.memory:
        config['memory'] = args.memory
    if args.motd:
        config['motd'] = args.motd
    if args.no_bluemap:
        config['bluemap'] = False
    if args.pregen:
        config['pregen'] = {'radius': args.pregen}

    # Backup defaults for permanent tier
    if args.tier == 'permanent':
        config['backup'] = {'interval': '24h', 'keep': 3}

    # World import: URL goes straight into manifest; local file gets copied first
    if args.world:
        if mclib.is_url(args.world):
            config['world'] = args.world
        else:
            container_path = mclib.setup_world_import(root, args.name, args.world)
            config['world'] = container_path

    try:
        mclib.add_server(manifest, args.name, config)
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    # Save manifest
    mclib.save_manifest(manifest, manifest_path)

    # Create server directory + env (before mc-generate, which validates
    # the compose and needs the env_file to exist)
    mclib.setup_server_dir(root, args.name, template_path)

    # Run mc-generate
    generate_script = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'mc-generate')
    subprocess.run([sys.executable, generate_script], check=True)

    # Copy world data from another server
    if args.world_from:
        try:
            mclib.copy_world_from(root, args.world_from, args.name)
            print(f"  World data copied from '{args.world_from}'")
        except ValueError as e:
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    # BlueMap EULA auto-acceptance
    server = manifest['servers'][args.name]
    has_bluemap = server.get('bluemap', False)
    if has_bluemap is not False:
        mod_groups = manifest.get('mod_groups', {})
        resolved = mclib.resolve_mods(server, mod_groups)
        if has_bluemap is True or 'bluemap' in resolved:
            mclib.setup_bluemap_eula(root, args.name)
            # Also launch background poller in case BlueMap overwrites our pre-created config
            poll_script = mclib.BLUEMAP_EULA_POLL_SCRIPT.format(name=args.name)
            subprocess.Popen(
                ['bash', '-c', poll_script],
                cwd=root, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            print("  BlueMap EULA pre-accepted (background poller running)")

    # Summary
    print(f"\nServer '{args.name}' created:")
    print(f"  Address:  {args.name}.mc.danny.is")
    if server.get('bluemap') is not False and server.get('bluemap_port'):
        print(f"  BlueMap:  https://map-{args.name}.mc.danny.is")
    if server.get('world'):
        print(f"  World:    imported via itzg WORLD env var on first start")
    if args.world_from:
        print(f"  World:    copied from '{args.world_from}'")
    if server.get('pregen'):
        print(f"  Pre-gen:  {server['pregen']['radius']} block radius (starts on first connect)")
    print(f"  Env file: servers/{args.name}/env")
    print(f"\nNext steps:")
    print(f"  1. Review/edit servers/{args.name}/env")
    print(f"  2. mc-start {args.name}")


if __name__ == '__main__':
    main()
