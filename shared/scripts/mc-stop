#!/usr/bin/env bash
# Stop one or all MC servers.
set -euo pipefail

cd /opt/minecraft

if [ $# -eq 0 ]; then
  # Stop all MC servers (but not acme-dns or mc-router)
  servers=$(docker compose ps --format '{{.Service}}' | grep -v -E '^(acme-dns|mc-router)$' || true)
  if [ -n "$servers" ]; then
    docker compose stop $servers
  fi
else
  # Stop server + backup sidecar (if it exists)
  services="$1"
  if docker compose config --services 2>/dev/null | grep -q "^${1}-backups$"; then
    services="${1}-backups $1"
  fi
  docker compose stop $services
fi
