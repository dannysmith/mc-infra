#!/usr/bin/env python3
"""Show status of all Minecraft servers."""

import json
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import mclib


def find_project_root():
    d = os.path.dirname(os.path.abspath(__file__))
    while d != '/':
        if os.path.exists(os.path.join(d, 'manifest.yml')):
            return d
        d = os.path.dirname(d)
    return '/opt/minecraft'


def get_container_state(name):
    """Get container state via docker compose ps."""
    try:
        result = subprocess.run(
            ['docker', 'compose', 'ps', '--format', 'json', name],
            capture_output=True, text=True, cwd=find_project_root(),
        )
        if result.returncode != 0 or not result.stdout.strip():
            return 'not created'
        data = json.loads(result.stdout.strip())
        return data.get('State', 'unknown')
    except (FileNotFoundError, json.JSONDecodeError):
        return 'unknown'


def get_memory_usage(name):
    """Get memory usage via docker stats."""
    try:
        result = subprocess.run(
            ['docker', 'stats', '--no-stream', '--format',
             '{{.MemUsage}}', name],
            capture_output=True, text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip().split('/')[0].strip()
    except FileNotFoundError:
        pass
    return '-'


def get_player_count(name):
    """Get player count via RCON."""
    try:
        result = subprocess.run(
            ['docker', 'exec', name, 'rcon-cli', 'list'],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0:
            # Output: "There are X of a max of Y players online: ..."
            line = result.stdout.strip()
            if 'There are' in line:
                parts = line.split()
                return f"{parts[2]}/{parts[8]}"
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return '-'


def main():
    root = find_project_root()
    manifest = mclib.load_manifest(os.path.join(root, 'manifest.yml'))

    # Header
    print(f"{'SERVER':<14}{'TIER':<16}{'STATE':<10}{'MEMORY':<10}{'PLAYERS':<9}{'ADDRESS'}")
    print('-' * 80)

    for name, server in manifest['servers'].items():
        tier = server.get('tier', 'ephemeral')
        state = get_container_state(name)
        memory = get_memory_usage(name) if state == 'running' else '-'
        players = get_player_count(name) if state == 'running' else '-'
        address = f"{name}.mc.danny.is"
        print(f"{name:<14}{tier:<16}{state:<10}{memory:<10}{players:<9}{address}")


if __name__ == '__main__':
    main()
