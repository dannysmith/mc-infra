#!/usr/bin/env python3
"""Fetch itzg/docker-minecraft-server docs and concatenate into a single reference file."""

import subprocess
import tempfile
from datetime import date
from pathlib import Path

REPO = "https://github.com/itzg/docker-minecraft-server.git"
OUTPUT_DIR = "docs/reference"
OUTPUT_FILE = "itzg-docker-minecraft-server.md"

# Preferred top-level ordering. Unlisted directories append at the end.
SECTION_ORDER = [
    ".",  # root-level files (index.md, data-directory.md, variables.md)
    "configuration",
    "versions",
    "types-and-platforms",
    "mods-and-plugins",
    "sending-commands",
    "misc",
]

# Files to skip (not useful as reference content)
SKIP_FILES = {"requirements.txt"}


def slug_to_title(slug: str) -> str:
    """Convert kebab-case slug to title case, with minor fixups."""
    return slug.replace("-", " ").replace("_", " ").title()


def heading_for_file(rel_path: Path) -> str:
    """Derive a markdown heading from a file's relative path."""
    name = rel_path.stem
    if name == "index":
        # Use parent directory name for index files
        parent = rel_path.parent.name
        return slug_to_title(parent) if parent else "Introduction"
    return slug_to_title(name)


def depth_of(rel_path: Path) -> int:
    """How many directory levels deep (used to pick heading level)."""
    parts = [p for p in rel_path.parent.parts if p != "."]
    return len(parts)


# Entry types: "section" (heading only), "section_content" (heading + file content), "file"
Entry = tuple[str, str | Path]


def gather_entries(docs_dir: Path) -> list[Entry]:
    """Walk docs_dir and return an ordered list of section headers and file paths."""
    # Group files by their top-level section
    sections: dict[str, list[Path]] = {}
    for md in sorted(docs_dir.rglob("*.md")):
        rel = md.relative_to(docs_dir)
        if rel.name in SKIP_FILES:
            continue
        section = str(rel.parts[0]) if len(rel.parts) > 1 else "."
        sections.setdefault(section, []).append(rel)

    # Sort each section: index.md first, then alphabetical
    for files in sections.values():
        files.sort(key=lambda p: (p.name != "index.md", str(p)))

    # Build ordered list with section headers injected
    entries: list[Entry] = []
    seen: set[str] = set()

    def add_section(section: str):
        if section not in sections:
            return
        files = sections[section]
        if section == ".":
            # Root files — no section header, just emit files
            for f in files:
                entries.append(("file", f))
        else:
            # Only count index.md as a section index if it's a direct child
            # (e.g. types-and-platforms/index.md, not misc/deployment/index.md)
            has_index = files and files[0].name == "index.md" and len(files[0].parts) == 2
            if has_index:
                # Section heading + index content merged together
                entries.append(("section_content", files[0]))
                files = files[1:]
            else:
                # Section heading only (no index.md to provide content)
                entries.append(("section", section))
            for f in files:
                entries.append(("file", f))
        seen.add(section)

    for section in SECTION_ORDER:
        add_section(section)
    for section in sorted(sections):
        if section not in seen:
            add_section(section)

    return entries


def toc_indent(rel_path: Path, is_root_section: bool) -> str:
    """Determine TOC indentation for a file entry."""
    parts = [p for p in rel_path.parent.parts if p != "."]
    if is_root_section:
        # Root files (no section parent) — flush left
        return ""
    # Files in sections: 1 level for being in a section, +1 per subdirectory depth
    depth = len(parts)  # e.g. configuration/foo.md = 1, misc/autopause-autostop/x.md = 2
    return "  " * depth


def build_toc(entries: list[Entry]) -> str:
    """Build a markdown table of contents."""
    lines = []
    in_root = True  # Track whether we're in the root section (no header)
    for kind, value in entries:
        if kind == "section":
            in_root = False
            title = slug_to_title(value)
            anchor = title.lower().replace(" ", "-")
            lines.append(f"- [{title}](#{anchor})")
        elif kind == "section_content":
            in_root = False
            title = heading_for_file(value)
            anchor = title.lower().replace(" ", "-")
            lines.append(f"- [{title}](#{anchor})")
        else:
            rel = value
            title = heading_for_file(rel)
            anchor = title.lower().replace(" ", "-").replace("/", "")
            indent = toc_indent(rel, in_root)
            lines.append(f"{indent}- [{title}](#{anchor})")
    return "\n".join(lines)


def concatenate(docs_dir: Path, entries: list[Entry], commit_sha: str) -> str:
    """Build the final concatenated markdown document."""
    parts = []
    file_count = sum(1 for kind, _ in entries if kind != "section")

    # Header
    parts.append("# itzg/docker-minecraft-server Documentation")
    parts.append("")
    parts.append(f"> Generated from <https://github.com/itzg/docker-minecraft-server> (commit {commit_sha[:7]})")
    parts.append(f"> Date: {date.today().isoformat()}")
    parts.append(f"> {file_count} source files")
    parts.append(">")
    parts.append("> Do not edit. Regenerate with `scripts/fetch-itzg-docs`.")
    parts.append("")

    # TOC
    parts.append("## Table of Contents")
    parts.append("")
    parts.append(build_toc(entries))
    parts.append("")

    # Content
    for kind, value in entries:
        if kind == "section":
            # Heading-only section (no index.md content)
            parts.append("---")
            parts.append("")
            parts.append(f"## {slug_to_title(value)}")
            parts.append("")
            continue

        if kind == "section_content":
            # Section heading with index.md content merged in
            rel = value
            title = heading_for_file(rel)
            parts.append("---")
            parts.append("")
            parts.append(f"## {title}")
            parts.append("")
            content = (docs_dir / rel).read_text().strip()
            lines = content.split("\n")
            if lines and lines[0].startswith("# "):
                lines = lines[1:]
                content = "\n".join(lines).strip()
            parts.append(content)
            parts.append("")
            continue

        # Regular file
        rel = value
        title = heading_for_file(rel)
        # Files in root get ##, files in sections get ###, deeper get ####
        depth = depth_of(rel)
        level = min(depth + 2, 5)  # cap at #####
        heading = "#" * level

        parts.append("---")
        parts.append("")
        parts.append(f"{heading} {title}")
        parts.append("")

        content = (docs_dir / rel).read_text().strip()
        lines = content.split("\n")
        if lines and lines[0].startswith("# "):
            lines = lines[1:]
            content = "\n".join(lines).strip()

        parts.append(content)
        parts.append("")

    return "\n".join(parts)


def main():
    project_root = Path(__file__).resolve().parent.parent
    output_path = project_root / OUTPUT_DIR / OUTPUT_FILE

    with tempfile.TemporaryDirectory() as tmp:
        tmp_path = Path(tmp)

        # Shallow sparse clone — just the docs/ directory
        print("Cloning docs from itzg/docker-minecraft-server...")
        subprocess.run(
            ["git", "clone", "--depth", "1", "--filter=blob:none", "--sparse", REPO, "repo"],
            cwd=tmp_path, capture_output=True, check=True,
        )
        repo_dir = tmp_path / "repo"
        subprocess.run(
            ["git", "sparse-checkout", "set", "docs"],
            cwd=repo_dir, capture_output=True, check=True,
        )

        # Get commit SHA
        result = subprocess.run(
            ["git", "rev-parse", "HEAD"],
            cwd=repo_dir, capture_output=True, text=True, check=True,
        )
        commit_sha = result.stdout.strip()

        docs_dir = repo_dir / "docs"
        if not docs_dir.is_dir():
            print("Error: docs/ directory not found in cloned repo")
            raise SystemExit(1)

        entries = gather_entries(docs_dir)
        file_count = sum(1 for kind, _ in entries if kind == "file")
        print(f"Found {file_count} documentation files")

        content = concatenate(docs_dir, entries, commit_sha)

        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(content)
        print(f"Written to {output_path.relative_to(project_root)}")


if __name__ == "__main__":
    main()
