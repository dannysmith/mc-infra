# World data (huge, backed up separately)
servers/*/data/

# Local backups
shared/backups/
backups/

# Shared mod JARs (non-Modrinth, dev builds, etc.)
shared/mods/*.jar

# Resolved secrets (only .env.tpl is tracked)
.env
!.env.tpl
.secrets/

# Generated reference docs (regenerate with scripts/fetch-itzg-docs)
docs/reference/itzg-docker-minecraft-server.md

# Python venv (local dev only)
.venv/
__pycache__/
.pytest_cache/

# OS / editor
.DS_Store
*.swp
*~
